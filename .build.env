# Docker build configuration
# You can customize these values for your environment

# Go module proxy (China mirrors for faster downloads)
GOPROXY=https://goproxy.cn,https://goproxy.io,direct

# Alternative Go proxies (uncomment to use):
# GOPROXY=https://mirrors.aliyun.com/goproxy/,direct
# GOPROXY=https://goproxy.baidu.com,direct
# GOPROXY=https://mirrors.tencent.com/go/,direct

# Go checksum database
GOSUMDB=sum.golang.google.cn

# Alpine mirror (for apk packages)
ALPINE_MIRROR=mirrors.aliyun.com

# Alternative Alpine mirrors (uncomment to use):
# ALPINE_MIRROR=mirrors.tencent.com
# ALPINE_MIRROR=mirrors.tuna.tsinghua.edu.cn
# ALPINE_MIRROR=dl-cdn.alpinelinux.org  # Official (default)
